# =============================================================================
# Gramoz Server — Environment Configuration
# =============================================================================

# Application 
NODE_ENV=development
PORT=5000

# Frontend URL — used for payment callback redirects (SSLCommerz success/fail/cancel)
FRONTEND_URL=http://localhost:3000

# Admin email — receives low-stock alerts and other admin notifications
ADMIN_EMAIL=admin@gramoz.com

# Products with stock at or below this number trigger a low-stock alert email
LOW_STOCK_THRESHOLD=5

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_NAME=platform_db
DB_USER=platform_user
DB_PASSWORD=platform_pass
DATABASE_URL=postgresql://platform_user:platform_pass@localhost:5433/platform_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@localhost:6380

# Email Configuration
EMAIL_API_KEY=re_api_key
EMAIL_FROM=onboarding@resend.dev
EMAIL_BASE_URL=https://api.resend.com
EMAIL_TIMEOUT=10s

# Authentication Configuration
AUTH_JWT_SECRET=verysecretpassword
AUTH_JWT_EXPIRES_IN=15m
AUTH_JWT_REFRESH_EXPIRES_IN=7d
AUTH_VERIFY_EMAIL_TOKEN_EXPIRES_IN=4h
AUTH_RESET_PASSWORD_TOKEN_EXPIRES_IN=1h
AUTH_BCRYPT_SALT_ROUNDS=10

# ayment Gateway Credential
SSLCOMMERZ_STORE_ID=gramo6a09a6a42ff2d
SSLCOMMERZ_STORE_SECRET=gramo6a09a6a42ff2d@ssl
SSLCOMMERZ_STORE_NAME=testgramoxx6g
SSLCOMMERZ_IS_SANDBOX=true

# Steadfast Courier Credentials
# Get from: https://portal.steadfast.com.bd → Profile → API Credentials
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=

# Cloudflare R2 Storage (S3-compatible)
# How to get credentials:
#   1. Go to Cloudflare Dashboard → R2 → Manage R2 API Tokens
#   2. Create a token with "Object Read & Write" on your bucket
#   3. Paste Account ID, Access Key, and Secret Key below
# Leave empty to use local disk (development only — files lost on redeploy)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gramoz-media
R2_PUBLIC_URL=https://media.gramoz.com

# Cookie signing secret — must be a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=1c1ccc374da686a8f89e85d628dfd8771875d64f8fd431adfc7d87ae5f7b94ff
