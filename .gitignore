# ==============================================================================
# Gramoz Monorepo .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Shared / Global Rules
# ------------------------------------------------------------------------------
# These rules apply everywhere in the repository (e.g. node_modules in any folder)
node_modules/
.pnp
.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
*.pem
*.key

# ------------------------------------------------------------------------------
# Web Frontend (Next.js)
# ------------------------------------------------------------------------------
web/.next/
web/out/
web/build/
web/.vercel/
web/next-env.d.ts

# ------------------------------------------------------------------------------
# Server Backend (NestJS)
# ------------------------------------------------------------------------------
server/dist/
server/.webpack/
server/.serverless/

# Ignore dynamically uploaded assets but keep the directory structure
server/public/uploads/*
!server/public/uploads/.gitkeep

# ------------------------------------------------------------------------------
# IDEs and OS Files
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
